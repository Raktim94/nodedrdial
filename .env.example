# ============================================
# TwilioHub OSS — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── App ──────────────────────────────────────
NODE_ENV=production
APP_PORT=3001
APP_URL=http://localhost
FRONTEND_URL=http://localhost

# ── Security ─────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_DIFFERENT_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Used to encrypt Twilio credentials at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_KEY_OPENSSL_RAND_HEX_32

# ── Database ──────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=twiliohub
POSTGRES_USER=twiliohub
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Email (SMTP) ──────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM="TwilioHub <noreply@example.com>"

# ── File Storage ──────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# ── OpenRouter AI ─────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-exp:free

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ── Setup ─────────────────────────────────────
# Set to true after initial setup is complete (auto-set by installer)
SETUP_COMPLETED=false

# ── Nginx ─────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ── Backup ────────────────────────────────────
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
